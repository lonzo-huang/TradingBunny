{
  "uid": "polymarket-pde-strategy",
  "title": "Polymarket PDE Strategy (Dual-Phase Engine)",
  "tags": ["polymarket", "pde", "trading", "dual-phase"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "instanceName": "Prometheus",
        "pluginId": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Prometheus",
        "options": [],
        "query": "prometheus"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Strategy Phase",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "pde_strategy_state",
          "legendFormat": "Phase",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "value": "0", "text": "Idle" },
            { "type": "value", "value": "1", "text": "Phase A (EV)" },
            { "type": "value", "value": "2", "text": "Phase B (Tail)" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "gray", "value": 0 },
              { "color": "blue", "value": 1 },
              { "color": "orange", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Remaining Time",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "pde_remaining_time",
          "legendFormat": "Seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "max": 300,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "orange", "value": 60 },
              { "color": "yellow", "value": 120 },
              { "color": "green", "value": 180 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Delta P (Price Offset)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "pde_delta_p",
          "legendFormat": "{{token_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 2
        }
      }
    },
    {
      "id": 4,
      "title": "Phase A: Theoretical Probability (p_up)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "pde_p_up",
          "legendFormat": "{{token_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "min": 0
        }
      }
    },
    {
      "id": 5,
      "title": "Phase A: Expected Value (EV)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "pde_ev",
          "legendFormat": "{{token_type}}-{{side}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 4
        }
      }
    },
    {
      "id": 6,
      "title": "Phase A: Volatility (Sigma)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "pde_sigma",
          "legendFormat": "Sigma",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 6
        }
      }
    },
    {
      "id": 7,
      "title": "Phase B: Flip Probability",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "pde_p_flip",
          "legendFormat": "{{token_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "min": 0
        }
      }
    },
    {
      "id": 8,
      "title": "Phase B: Tail EV",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "pde_ev_tail",
          "legendFormat": "{{token_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 4
        }
      }
    },
    {
      "id": 9,
      "title": "Phase A Trades Count",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "pde_phase_a_trades",
          "legendFormat": "Trades",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "id": 10,
      "title": "Total Trades by Phase",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "rate(pde_trades_total[5m])",
          "legendFormat": "{{phase}}-{{token_type}}-{{side}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Unrealized PnL",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 20 },
      "targets": [
        {
          "expr": "pde_unrealized_pnl",
          "legendFormat": "{{token_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Realized PnL",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 24 },
      "targets": [
        {
          "expr": "pde_realized_pnl",
          "legendFormat": "{{token_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 0 }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "title": "Position Size",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "pde_position_size",
          "legendFormat": "{{token_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "max": 200,
          "min": 0
        }
      }
    }
  ]
}
